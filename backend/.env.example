# Groq API — create a new token at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model routing (see docs/ARCHITECTURE.md for rationale)
# gemma2-9b-it (the model named in the assignment brief) was decommissioned by
# Groq; llama-3.1-8b-instant is the closest available fast/cheap substitute.
GROQ_EXTRACTION_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_URL=postgresql+psycopg2://hcp_crm:hcp_crm@localhost:5432/hcp_crm

# App
ENV=development
CORS_ORIGINS=http://localhost:5173
